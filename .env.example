# PostgreSQL
POSTGRES_DB=enshift
POSTGRES_USER=enshift
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# NestJS
API_PORT=3000
DATABASE_URL=postgresql://enshift:change-me-in-production@postgres:5432/enshift
DATABASE_CONNECT_ON_STARTUP=true
JWT_SECRET=replace-with-a-random-32-byte-or-longer-secret
JWT_EXPIRES_IN=8h
SEED_OWNER_EMAIL=owner@demo.enshift.local
SEED_OWNER_PASSWORD=ChangeMe123!

# React / Vite (browser-visible values must never contain secrets)
VITE_API_BASE_URL=/api
